&НаКлиенте
Асинх Процедура ОбработатьОшибки()

	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
		
	МассивОшибок = ПроверкаНаОшибкиНаСервере();
	
	Если МассивОшибок.Количество() = 0 Тогда
		ДобавлениеЗаписиВТаблицуНаСервере();
		Возврат;
	КонецЕсли;
	
	ТекстОшибок = "";
	ЕстьФатальныеОшибки = Ложь;	
	Для Каждого Ошибка из МассивОшибок Цикл
		Если Ошибка.БлокироватьАдминскуюУстановку = Истина Тогда
			ЕстьФатальныеОшибки = Истина;
		КонецЕсли;
		ТекстОшибок = ТекстОшибок + Символы.ПС + Ошибка.ОписаниеОшибки + Символы.ПС;
	КонецЦикла;
	
	ПользовательскиеКнопки = Новый СписокЗначений;
	ПользовательскиеКнопки.Добавить("Отмена", "Отмена");
	
	Если НЕ ЕстьФатальныеОшибки Тогда
		ПользовательскиеКнопки.Добавить("ВсеРавноДобавить", "Все равно добавить строку");	
	КонецЕсли;
	
	Если Не ПустаяСтрока(ТекстОшибок) Тогда		
		Ответ = Ждать ВопросАсинх(ТекстОшибок, ПользовательскиеКнопки, 10);
		Если Ответ = "Отмена" ИЛИ Ответ = КодВозвратаДиалога.Таймаут Тогда
			Возврат;
		КонецЕсли;	
	КонецЕсли;
	
	ДобавлениеЗаписиВТаблицуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьОшибкуВМассив(МассивОшибок, Текст, ТребуетПодтверждения)
	
	СтруктураОшибки = Новый Структура;
	СтруктураОшибки.Вставить("ОписаниеОшибки", Текст);
	СтруктураОшибки.Вставить("БлокироватьАдминскуюУстановку", ТребуетПодтверждения);
	
	МассивОшибок.Добавить(СтруктураОшибки);
	
КонецПроцедуры

&НаСервере
Функция ПроверкаНаОшибкиНаСервере()

	МассивОшибок = Новый Массив;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	МаксДнейОтступаДатыЗапрета = БазыДанных.НайтиСтроки(Новый Структура("Идентификатор", параметр_БазаДанных))[0].ОтступДнейПериодаМакс;
	РазностьДней = (НачалоДня(ТекущаяДата) - НачалоДня(параметр_ДатаОткрытия)) / (60 * 60 * 24);
	
	ВыбранныеОрганизации = ТаблицаОрганизаций.НайтиСтроки(Новый Структура("Выбор", Истина));
	
	Если параметр_ДатаОтключения < (КонецДня(ТекущаяДата) + 1) Тогда
		ДобавитьОшибкуВМассив(МассивОшибок, "ДатаОтключения не может быть меньше завтрашнего дня", Истина);
	КонецЕсли;
	
	Если ВыбранныеОрганизации.Количество() = 0 Тогда
		ДобавитьОшибкуВМассив(МассивОшибок, "Не выбрана ни одна организация", Истина);
	КонецЕсли;
	
	Если РазностьДней >= МаксДнейОтступаДатыЗапрета Тогда
		ТекстОшибки = СтрШаблон("Согласно настройкам БД нельзя устанавливать дату открытия больше чем на %1 дней.", МаксДнейОтступаДатыЗапрета);
		Если РольДоступна("ПолныеПрава") Тогда
			ДобавитьОшибкуВМассив(МассивОшибок, ТекстОшибки, Ложь);
		Иначе
			ДобавитьОшибкуВМассив(МассивОшибок, ТекстОшибки, Истина);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивОшибок;
	
КонецФункции

