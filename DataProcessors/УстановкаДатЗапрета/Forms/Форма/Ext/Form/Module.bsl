&НаСервере
Процедура ДобавлениеЗаписиВТаблицуНаСервере()
	
	ТаблОрг = РеквизитФормыВЗначение("ТаблицаОрганизаций");
	ВыбранныеОрганизации = ТаблОрг.НайтиСтроки(Новый Структура("Выбор", Истина));
	Для Каждого Строка ИЗ ВыбранныеОрганизации Цикл
		
		МассивПользователейСОрганизацией = ДатыЗапрета.НайтиСтроки(Новый Структура("ПользовательИдентификатор, ОрганизацияИдентификатор", параметр_Пользователь, Строка.Идентификатор));
		Если МассивПользователейСОрганизацией.Количество() > 0 Тогда
			Для Каждого Стр Из МассивПользователейСОрганизацией Цикл
				ДатыЗапрета.Удалить(Стр);
			КонецЦикла;
		КонецЕсли;
		
		Стр = ДатыЗапрета.Добавить();
		Стр.ПользовательИдентификатор          		= параметр_Пользователь;
		Стр.Комментарий								= параметр_НомерЗадачи;
		Стр.ПользовательПредставление				= ПользователиИБ.НайтиСтроки(Новый Структура("Идентификатор", параметр_Пользователь))[0].name;
		Стр.ОрганизацияИдентификатор				= Строка.Идентификатор;
		Стр.ДатаОткрытия							= параметр_ДатаОткрытия;
		Стр.ДатаОкончанияСрокаДействияРазрещения	= параметр_ДатаОтключения;
		Стр.ОрганизацияПредставление				= ОрганизацииИБ.НайтиСтроки(Новый Структура("Идентификатор", Строка.Идентификатор))[0].name;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция СтруктураЗаписиОтправки(Строка)
	
	СтруктураПользователя = СтруктураПользователя(Строка.ПользовательИдентификатор);

	Если ЗначениеЗаполнено(Строка.ОрганизацияИдентификатор) Тогда
		Организация = ДанныеИзВнеш("ОрганизацииИБ", Строка.ОрганизацияИдентификатор);
		СтруктураОрганизации = Новый Структура; 
		СтруктураОрганизации.Вставить("guid",  Организация.guid);
		СтруктураОрганизации.Вставить("inn",   Организация.inn);
		СтруктураОрганизации.Вставить("kpp",   Организация.kpp);
		СтруктураОрганизации.Вставить("name",  Организация.name);
	КонецЕсли;
	ДанныеДляУстановки = Новый Структура;
	ДанныеДляУстановки.Вставить("users", 		СтруктураПользователя);
	ДанныеДляУстановки.Вставить("org", 			СтруктураОрганизации);
	ДанныеДляУстановки.Вставить("DateDelete", 	XMLСтрока(Строка.ДатаОкончанияСрокаДействияРазрещения));
	ДанныеДляУстановки.Вставить("dateInstall", 	XMLСтрока(Строка.ДатаОткрытия)); 
	ДанныеДляУстановки.Вставить("taskNumber", 	Строка.Комментарий);
		
	Возврат ДанныеДляУстановки;
	
КонецФункции

&НаСервере
Функция СтруктураПользователя(ИдентификаторПользователя)
	
	Пользователь = ДанныеИзВнеш("ПользователиИБ", ИдентификаторПользователя);
	СтруктураПользователя = Новый Структура;
	СтруктураПользователя.Вставить("guid", Пользователь.guid);
	СтруктураПользователя.Вставить("domainName", Пользователь.domainName);
	СтруктураПользователя.Вставить("name", Пользователь.name);
	Возврат СтруктураПользователя;

КонецФункции

&НаСервере
Функция ДанныеИзВнеш(Знач ИмяТаблицы, Знач Идентификатор)
	
	СтрокаТаблицы = ЭтотОбъект[ИмяТаблицы].НайтиСтроки(Новый Структура("Идентификатор", Идентификатор));
	Возврат СтрокаТаблицы[0];
	
КонецФункции

&НаСервере
Процедура УстановитьДатуЗапретаПользователямНаСервере()
	
	МассивЗаписей = Новый Массив;
	
	Для Каждого Строка из ДатыЗапрета Цикл
		СтруктураЗаписи = СтруктураЗаписиОтправки(Строка); 
		МассивЗаписей.Добавить(СтруктураЗаписи);
	КонецЦикла;
	
	ДанныеДляОтправки = МодульКоннекторХТТП().ОбъектВJson(МассивЗаписей);
	
	Ответ = ВыполнитьЗапросHTTP("accessPeriods", "Post", ДанныеДляОтправки);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеСпискаБаз()
	
	Если НЕ Метаданные.Справочники.Найти("БазыДанных") = Неопределено Тогда
		
		ТекстЗапроса = ТекстЗапросаПоСпискуБаз();
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса; 
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Стр = БазыДанных.Добавить();
			ЗаполнитьЗначенияСвойств(Стр,Выборка);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаПоСпискуБаз()
	
	Перем ТекстЗапроса;
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(т.Ссылка)) КАК Идентификатор,
	               |	ПРЕДСТАВЛЕНИЕ(т.АдресПубликацииВебСервисов) КАК АдресПубликации,
	               |	ПРЕДСТАВЛЕНИЕ(т.ВидКонфигурации) КАК Конфигурация,
	               |	ПРЕДСТАВЛЕНИЕ(т.Пользователь) КАК Пользователь,
	               |	т.Пользователь.Пароль КАК Пароль,
	               |	т.Наименование КАК Наименование,
	               |	ПРЕДСТАВЛЕНИЕ(т.СтатусБазы) КАК СтатусБазы,
	               |	ЕСТЬNULL(БазыДанныхДополнительныеРеквизиты.Значение, 90) КАК ОтступДнейПериодаМакс
	               |ИЗ
	               |	Справочник.БазыДанных КАК т
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.УстановленныеРасширенияКонфигурации.СрезПоследних(, Расширение = ЗНАЧЕНИЕ(Справочник.РасширенияКонфигураций.ИТ_Bорк)) КАК рст
	               |		ПО (рст.БазаДанных = т.Ссылка)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БазыДанных.ДополнительныеРеквизиты КАК БазыДанныхДополнительныеРеквизиты
	               |		ПО т.Ссылка = БазыДанныхДополнительныеРеквизиты.Ссылка
	               |			И (БазыДанныхДополнительныеРеквизиты.Свойство.Имя = ""ДнейУдаленияДатыЗапрета"")
	               |ГДЕ
	               |	ИСТИНА
	               |	И рст.Активно = ИСТИНА
	               |	И т.СтатусБазы = ЗНАЧЕНИЕ(Перечисление.СтатусыБаз.Рабочая)";
	//Если РольДоступна("ПолныеПрава") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И т.СтатусБазы = ЗНАЧЕНИЕ(Перечисление.СтатусыБаз.Рабочая)", "");
	//КонецЕсли;
	
	Возврат ТекстЗапроса;

КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицыДанных()
	
	ПользователиИБ.Очистить();
	ОрганизацииИБ.Очистить();
	МассивПользователей = ВыполнитьЗапросHTTP("users", "Get"); 		

	Для Каждого Строка ИЗ МассивПользователей Цикл
		Стр = ПользователиИБ.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Строка);
		Стр.Идентификатор = Новый УникальныйИдентификатор;
	КонецЦикла;
	
	МассивОрганизаций   = ВыполнитьЗапросHTTP("organizations", "Get");
	
	Для Каждого Строка ИЗ МассивОрганизаций Цикл 
		Стр = ОрганизацииИБ.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Строка);
		Стр.Идентификатор = Новый УникальныйИдентификатор;
		СтрокаОрганизации = ТаблицаОрганизаций.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаОрганизации, Стр);
	КонецЦикла;
	
	ДатыЗапретаИзВнешнейБазы();
	
КонецПроцедуры

&НаСервере
Функция ВыполнитьЗапросHTTP(Знач Ресурс, Знач Метод, Знач ОтправкаДанных = Неопределено)
	
	Перем Параметры;
	
	Метод = ВРег(Метод);
	
	Адрес = СтрШаблон("%1/hs/userManagement/%2", ВыбраннаяБаза, Ресурс);
	
	Параметры = МодульКоннекторХТТП().НовыеПараметры();
	Параметры.Аутентификация = МодульКоннекторХТТП().НоваяАутентификацияBasic();
	Параметры.Аутентификация.Пользователь = Логин;
	Параметры.Аутентификация.Пароль = Пароль;
	Параметры.Заголовки = Новый Соответствие;
	Параметры.Заголовки.Вставить("Content-Type", "text/json; charset=utf-8");
	
	Если Метод = "POST" Тогда		
		Результат = МодульКоннекторХТТП().Post(Адрес, ОтправкаДанных, Параметры);
	ИначеЕсли Метод = "GET" Тогда 
		Результат = МодульКоннекторХТТП().Get(Адрес, , Параметры);
		ЧтенДанных = Новый ЧтениеДанных(Результат.Тело);
		РезультатJSON = ЧтенДанных.ПрочитатьСимволы();
		Результат = МодульКоннекторХТТП().JsonВОбъект(РезультатJSON, ,Новый Структура("ПрочитатьВСоответствие", Ложь));
	ИначеЕсли Метод = "DELETE" Тогда
		Результат = МодульКоннекторХТТП().Delete(Адрес, ОтправкаДанных , Параметры);
	Иначе
		ВызватьИсключение "Неизвестный метод";
	КонецЕсли;
	
	Если Истина
	И ТипЗнч(Результат) = Тип("Структура")
	и Результат.Свойство("КодСостояния")
	и НЕ Результат.КодСостояния = 200
	Тогда
		ЧтенДанных = Новый ЧтениеДанных(Результат.Тело);
		ТелоОтвета = ЧтенДанных.ПрочитатьСимволы();
		Результат.Вставить("ТекстОшибки", ТелоОтвета);
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОчиститьДатыЗапретаПользователямНаСервере()
	
	ТаблЧасть = ДатыЗапрета.Выгрузить();
	МассивПользователейДляУдаления = ТаблЧасть.ВыгрузитьКолонку("ПользовательИдентификатор");
	
	ПользователиКОтправке = Новый Массив;
	Для Каждого Строка Из МассивПользователейДляУдаления Цикл
		Пользователь = СтруктураПользователя(Строка);
		ДанныеДляУстановки = Новый Структура;
		ДанныеДляУстановки.Вставить("users", 		Пользователь);
		ПользователиКОтправке.Добавить(ДанныеДляУстановки);
	КонецЦикла;
		
	ДанныеДляОтправки = МодульКоннекторХТТП().ОбъектВJson(ПользователиКОтправке);
	Ответ = ВыполнитьЗапросHTTP("accessPeriods", "Delete", ДанныеДляОтправки);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборВТаблицеОрганизаций(Знач ПараметрКнопки)

	Для Каждого Строка Из ТаблицаОрганизаций Цикл
		Строка.Выбор = ПараметрКнопки; 	
	КонецЦикла;

КонецПроцедуры

