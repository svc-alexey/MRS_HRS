#Область HTMLИнтерфейс

&НаСервереБезКонтекста
Функция РасшифроватьКомандуHTMLИзФрагмента(Знач ФрагментBase64URL)
	
	Если ПустаяСтрока(ФрагментBase64URL) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Стр = ФрагментBase64URL;
	Стр = СтрЗаменить(Стр, "-", "+");
	Стр = СтрЗаменить(Стр, "_", "/");
	Пока СтрДлина(Стр) % 4 <> 0 Цикл
		Стр = Стр + "=";
	КонецЦикла;
	
	Попытка
		ДД = Base64Значение(Стр);
		JsonТекст = ПолучитьСтрокуИзДвоичныхДанных(ДД, КодировкаТекста.UTF8);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(JsonТекст);
	Возврат ПрочитатьJSON(Чтение);
	
КонецФункции

&НаКлиенте
Функция ИмяКомандыИнтерфейса(Команда)
	
	Если Команда = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Возврат Строка(Команда.c);
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Возврат Строка(Команда.Получить("c"));
	КонецЕсли;
	Возврат "";
	
КонецФункции

&НаКлиенте
Процедура ПолеHTMLДокументаПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Href = "";
	Если ДанныеСобытия <> Неопределено Тогда
		Попытка
			Href = ДанныеСобытия.Href;
		Исключение
			Href = "";
		КонецПопытки;
	КонецЕсли;
	
	Если ПустаяСтрока(Href) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ СтрНачинаетсяС(НРег(Href), "mrsdz://") Тогда
		Возврат;
	КонецЕсли;
	
	Поз = СтрНайти(Href, "#");
	Если Поз = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Фрагмент = Сред(Href, Поз + 1);
	Если ПустаяСтрока(Фрагмент) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Команда = РасшифроватьКомандуHTMLИзФрагмента(Фрагмент);
	Имя = ИмяКомандыИнтерфейса(Команда);
	
	Если Имя = "addRow" Тогда
		ОбработатьОшибки();
		Возврат;
	ИначеЕсли Имя = "install" Тогда
		УстановитьДатуЗапретаПользователям(Неопределено);
		Возврат;
	ИначеЕсли Имя = "clearQueue" Тогда
		ОчиститьТаблицуОчередиНаСервере();
		ОбновитьОтображениеHTML();
		Возврат;
	ИначеЕсли Имя = "refreshDb" Тогда
		ОбновитьИнформацию(Неопределено);
		Возврат;
	ИначеЕсли Имя = "checkAll" Тогда
		ВыборВТаблицеОрганизаций(Истина);
		ОбновитьОтображениеHTML();
		Возврат;
	ИначеЕсли Имя = "uncheckAll" Тогда
		ВыборВТаблицеОрганизаций(Ложь);
		ОбновитьОтображениеHTML();
		Возврат;
	КонецЕсли;
	
	ВыполнитьКомандуИнтерфейсаНаСервере(Команда);
	ОбновитьОтображениеHTML();
	
КонецПроцедуры

&НаКлиенте
