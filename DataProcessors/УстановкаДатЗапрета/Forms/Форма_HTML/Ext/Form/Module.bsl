&НаСервере
Процедура ВыполнитьКомандуИнтерфейсаНаСервере(Знач Команда)
	
	Если Команда = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Имя = "";
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Имя = Строка(Команда.c);
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Имя = Строка(Команда.Получить("c"));
	Иначе
		Возврат;
	КонецЕсли;
	
	Если Имя = "selectBase" Тогда
		ИдБазы = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИдБазы = Строка(Команда.id);
		Иначе
			ИдБазы = Строка(Команда.Получить("id"));
		КонецЕсли;
		ВыполнитьВыборБазыНаСервере(ИдБазы, Истина);
	ИначеЕсли Имя = "togglePickBase" Тогда
		ИндСтр = HTML_ИндексСтрокиИзКомандыМоста(Команда);
		Если ИндСтр < 0 Или ИндСтр >= БазыДанных.Количество() Тогда
			Возврат;
		КонецЕсли;
		СтрБ = БазыДанных.Получить(ИндСтр);
		Ид = СтрБ.Идентификатор;
		Вкл = НЕ HTML_ИдВПодбореБаз(Ид);
		HTML_ПодборБазПереключить(Ид, Вкл);
	ИначеЕсли Имя = "removePickBase" Тогда
		ИндСтр = HTML_ИндексСтрокиИзКомандыМоста(Команда);
		МИд = HTML_МассивСтрокИзJson(HTML_JSONПодборБаз);
		Если ИндСтр < 0 Или ИндСтр >= МИд.Количество() Тогда
			Возврат;
		КонецЕсли;
		Ид = МИд[ИндСтр];
		HTML_ПодборБазПереключить(Ид, Ложь);
	ИначеЕсли Имя = "applyBases" Тогда
		HTML_ПрименитьПодборБаз();
	ИначеЕсли Имя = "clearBasePick" Тогда
		HTML_JSONПодборБаз = HTML_ПустойМассивСтрокJson();
		ВыполнитьВыборБазыНаСервере("", Истина);
	ИначеЕсли Имя = "activateBase" Тогда
		ИндСтр = HTML_ИндексСтрокиИзКомандыМоста(Команда);
		МИд = HTML_МассивСтрокИзJson(HTML_JSONПодборБаз);
		Если ИндСтр < 0 Или ИндСтр >= МИд.Количество() Тогда
			Возврат;
		КонецЕсли;
		Ид = МИд[ИндСтр];
		ВыполнитьВыборБазыНаСервере(Ид, Ложь);
	ИначеЕсли Имя = "togglePickUser" Тогда
		ИндСтр = HTML_ИндексСтрокиИзКомандыМоста(Команда);
		Если ИндСтр < 0 Или ИндСтр >= ПользователиИБ.Количество() Тогда
			Возврат;
		КонецЕсли;
		СтрП = ПользователиИБ.Получить(ИндСтр);
		Ид = Строка(СтрП.Идентификатор);
		Вкл = НЕ HTML_ИдВПодбореПользователей(Ид);
		HTML_ПодборПользователейПереключить(Ид, Вкл);
	ИначеЕсли Имя = "removePickUser" Тогда
		ИндСтр = HTML_ИндексСтрокиИзКомандыМоста(Команда);
		МИд = HTML_МассивСтрокИзJson(HTML_JSONПодборПользователей);
		Если ИндСтр < 0 Или ИндСтр >= МИд.Количество() Тогда
			Возврат;
		КонецЕсли;
		Ид = МИд[ИндСтр];
		HTML_ПодборПользователейПереключить(Ид, Ложь);
	ИначеЕсли Имя = "applyUsers" Тогда
		HTML_ПрименитьПодборПользователей();
	ИначеЕсли Имя = "clearUserPick" Тогда
		HTML_JSONПодборПользователей = HTML_ПустойМассивСтрокJson();
		параметр_Пользователь = "";
	ИначеЕсли Имя = "activateUser" Тогда
		ИндСтр = HTML_ИндексСтрокиИзКомандыМоста(Команда);
		МИд = HTML_МассивСтрокИзJson(HTML_JSONПодборПользователей);
		Если ИндСтр < 0 Или ИндСтр >= МИд.Количество() Тогда
			Возврат;
		КонецЕсли;
		параметр_Пользователь = МИд[ИндСтр];
	ИначеЕсли Имя = "setField" Тогда
		ИмяПоля = ""; ЗначПоля = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИмяПоля = Строка(Команда.n);
			ЗначПоля = Строка(Команда.v);
		Иначе
			ИмяПоля = Строка(Команда.Получить("n"));
			ЗначПоля = Строка(Команда.Получить("v"));
		КонецЕсли;
		УстановитьПолеФормыИзHTMLНаСервере(ИмяПоля, ЗначПоля);
	ИначеЕсли Имя = "toggleOrg" Тогда
		ИдОрг = HTML_ПолеСтрокаКоманды(Команда, "id");
		Вкл = HTML_ПолеБулевоКоманды(Команда, "v");
		УстановитьФлажокОрганизацииИзHTMLНаСервере(ИдОрг, Вкл);
	ИначеЕсли Имя = "tab" Тогда
		КодВкладки = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			КодВкладки = Строка(Команда.t);
		Иначе
			КодВкладки = Строка(Команда.Получить("t"));
		КонецЕсли;
		Если КодВкладки = "t1" Или КодВкладки = "t2" Или КодВкладки = "t3" Тогда
			АктивнаяВкладкаHTML = КодВкладки;
		КонецЕсли;
	ИначеЕсли Имя = "setOrgSel" Тогда
		ИдОрг = ""; Вкл = Ложь;
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИдОрг = Строка(Команда.id);
			Вкл = Команда.v = Истина;
		Иначе
			ИдОрг = Строка(Команда.Получить("id"));
			Вкл = Команда.Получить("v") = Истина;
		КонецЕсли;
		УстановитьФлажокОрганизацииИзHTMLНаСервере(ИдОрг, Вкл);
	ИначеЕсли Имя = "calNav" Тогда
		КодW = HTML_ПолеСтрокаКоманды(Команда, "w");
		СтрШаг = HTML_ПолеСтрокаКоманды(Команда, "s");
		Шаг = 0;
		Попытка
			Шаг = Число(СтрШаг);
		Исключение
			Шаг = 0;
		КонецПопытки;
		Если Шаг = 0 Тогда
			Возврат;
		КонецЕсли;
		Если КодW = "o" Тогда
			ГК = Число(HTML_КалОткрГод);
			МК = Число(HTML_КалОткрМесяц);
			Если ГК < 1900 Или МК < 1 Или МК > 12 Тогда
				ТС = ТекущаяДатаСеанса();
				ГК = Год(ТС);
				МК = Месяц(ТС);
			КонецЕсли;
			НовВид = ДобавитьМесяц(Дата(ГК, МК, 1), Шаг);
			HTML_КалОткрГод = Год(НовВид);
			HTML_КалОткрМесяц = Месяц(НовВид);
		ИначеЕсли КодW = "c" Тогда
			ГК = Число(HTML_КалОтклГод);
			МК = Число(HTML_КалОтклМесяц);
			Если ГК < 1900 Или МК < 1 Или МК > 12 Тогда
				ТС = ТекущаяДатаСеанса();
				ГК = Год(ТС);
				МК = Месяц(ТС);
			КонецЕсли;
			НовВид = ДобавитьМесяц(Дата(ГК, МК, 1), Шаг);
			HTML_КалОтклГод = Год(НовВид);
			HTML_КалОтклМесяц = Месяц(НовВид);
		КонецЕсли;
	ИначеЕсли Имя = "pickO" Тогда
		СтрД = HTML_ПолеСтрокаКоманды(Команда, "id");
		Д = ДатаИзСтрокиYYYYMMDD(СтрД);
		Если Д = Дата(1, 1, 1) Тогда
			Возврат;
		КонецЕсли;
		параметр_ДатаОткрытия = Д;
		HTML_КалОткрГод = Год(Д);
		HTML_КалОткрМесяц = Месяц(Д);
	ИначеЕсли Имя = "pickC" Тогда
		СтрД = HTML_ПолеСтрокаКоманды(Команда, "id");
		Д = ДатаИзСтрокиYYYYMMDD(СтрД);
		Если Д = Дата(1, 1, 1) Тогда
			Возврат;
		КонецЕсли;
		параметр_ДатаОтключения = Д;
		HTML_КалОтклГод = Год(Д);
		HTML_КалОтклМесяц = Месяц(Д);
	ИначеЕсли Имя = "flipOrg" Тогда
		ИндСтр = HTML_ИндексСтрокиИзКомандыМоста(Команда);
		Если ИндСтр < 0 Или ИндСтр >= ТаблицаОрганизаций.Количество() Тогда
			Возврат;
		КонецЕсли;
		СтрО = ТаблицаОрганизаций.Получить(ИндСтр);
		СтрО.Выбор = НЕ СтрО.Выбор;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьВыборБазыНаСервере(Знач ИдентификаторБазы, Знач СброситьПодборБаз = Истина)
	
	Если СброситьПодборБаз Тогда
		Если ПустаяСтрока(ИдентификаторБазы) Тогда
			HTML_JSONПодборБаз = HTML_ПустойМассивСтрокJson();
		Иначе
			МПодбор = Новый Массив;
			МПодбор.Добавить(ИдентификаторБазы);
			HTML_JSONПодборБаз = HTML_JsonИзМассиваСтрок(МПодбор);
		КонецЕсли;
	КонецЕсли;
	
	параметр_Пользователь = "";
	параметр_Организация = "";
	HTML_JSONПодборПользователей = HTML_ПустойМассивСтрокJson();
	ТаблицаОрганизаций.Очистить();
	ДатыЗапрета.Очистить();
	ОрганизацииИБ.Очистить();
	ПользователиИБ.Очистить();
	
	Если ПустаяСтрока(ИдентификаторБазы) Тогда
		параметр_БазаДанных = "";
		ВыбраннаяБаза = "";
		Логин = "";
		Пароль = "";
		Возврат;
	КонецЕсли;
	
	Найденные = БазыДанных.НайтиСтроки(Новый Структура("Идентификатор", ИдентификаторБазы));
	Если Найденные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаБазы = Найденные[0];
	Логин = СтрокаБазы.Пользователь;
	Пароль = СтрокаБазы.Пароль;
	ВыбраннаяБаза = СтрокаБазы.АдресПубликации;
	параметр_БазаДанных = ИдентификаторБазы;
	
	ЗаполнитьТаблицыДанных();
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьТаблицуОчередиНаСервере()
	
	ДатыЗапрета.Очистить();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПолеФормыИзHTMLНаСервере(Знач ИмяПоля, Знач Значение)
	
	Если ИмяПоля = "user" Тогда
		параметр_Пользователь = Значение;
	ИначеЕсли ИмяПоля = "org" Тогда
		параметр_Организация = Значение;
	ИначеЕсли ИмяПоля = "task" Тогда
		параметр_НомерЗадачи = Значение;
	ИначеЕсли ИмяПоля = "dOpen" Тогда
		параметр_ДатаОткрытия = ДатаИзСтрокиИнтерфейса(Значение);
		HTML_ВыровнятьВидКалендарейПодПоляФормы();
	ИначеЕсли ИмяПоля = "dClose" Тогда
		параметр_ДатаОтключения = ДатаИзСтрокиИнтерфейса(Значение);
		HTML_ВыровнятьВидКалендарейПодПоляФормы();
	ИначеЕсли ИмяПоля = "login" Тогда
		Логин = Значение;
	ИначеЕсли ИмяПоля = "password" И ЗначениеЗаполнено(Значение) Тогда
		Пароль = Значение;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДатаИзСтрокиИнтерфейса(Знач Стр)
	
	Стр = СокрЛП(Стр);
	Если ПустаяСтрока(Стр) Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;
	Части = СтрРазделить(Стр, "-");
	Если Части.Количество() <> 3 Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;
	Попытка
		Возврат Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));
	Исключение
		Возврат Дата(1, 1, 1);
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ДатаИзСтрокиYYYYMMDD(Знач Стр)
	
	Стр = СокрЛП(Стр);
	Если СтрДлина(Стр) <> 8 Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;
	Попытка
		ГЗ = Число(Лев(Стр, 4));
		МЗ = Число(Сред(Стр, 5, 2));
		ДЗ = Число(Сред(Стр, 7, 2));
		Возврат Дата(ГЗ, МЗ, ДЗ);
	Исключение
		Возврат Дата(1, 1, 1);
	КонецПопытки;
	
КонецФункции

&НаСервере
Процедура УстановитьФлажокОрганизацииИзHTMLНаСервере(Знач ИдОрг, Знач Вкл)
	
	Найденные = ТаблицаОрганизаций.НайтиСтроки(Новый Структура("Идентификатор", ИдОрг));
	Если Найденные.Количество() > 0 Тогда
		Найденные[0].Выбор = Вкл;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СформироватьТекстHTMLНаСервере()
	
	Попытка
		Возврат СобратьПолныйHTMLДокументНаСервере();
	Исключение
		ТекстОш = HTMLЭкранировать(ОписаниеОшибки());
		Возврат "<!DOCTYPE html><html><head><meta charset=""utf-8""/></head><body style=""font-family:Segoe UI,Arial,sans-serif;padding:12px;""><h1>Ошибка разметки</h1><p>"
			+ ТекстОш + "</p></body></html>";
	КонецПопытки;
	
