&НаСервере
Процедура УстановитьПолеФормыИзHTMLНаСервере(Знач ИмяПоля, Знач Значение)
	
	Если ИмяПоля = "user" Тогда
		параметр_Пользователь = Значение;
	ИначеЕсли ИмяПоля = "org" Тогда
		параметр_Организация = Значение;
	ИначеЕсли ИмяПоля = "task" Тогда
		параметр_НомерЗадачи = Значение;
	ИначеЕсли ИмяПоля = "dOpen" Тогда
		параметр_ДатаОткрытия = ДатаИзСтрокиИнтерфейса(Значение);
	ИначеЕсли ИмяПоля = "dClose" Тогда
		параметр_ДатаОтключения = ДатаИзСтрокиИнтерфейса(Значение);
	ИначеЕсли ИмяПоля = "login" Тогда
		Логин = Значение;
