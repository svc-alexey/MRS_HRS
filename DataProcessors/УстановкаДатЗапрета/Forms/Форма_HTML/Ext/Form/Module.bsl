&НаСервере
Функция HTML_ПустойМассивСтрокJson()
	
	Возврат "[]";
	
КонецФункции

&НаСервере
Функция HTML_МассивСтрокИзJson(Знач JsonТекст)
	
	Рез = Новый Массив;
	Если ПустаяСтрока(JsonТекст) Тогда
		Возврат Рез;
	КонецЕсли;
	Попытка
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(JsonТекст);
		Дан = ПрочитатьJSON(Чтение);
		Если ТипЗнч(Дан) <> Тип("Массив") Тогда
			Возврат Рез;
		КонецЕсли;
		Для Каждого Эл Из Дан Цикл
			Рез.Добавить(Строка(Эл));
		КонецЦикла;
	Исключение
	КонецПопытки;
	Возврат Рез;
	
КонецФункции

&НаСервере
Функция HTML_JsonИзМассиваСтрок(Знач МассивИд)
	
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, МассивИд);
	Возврат Запись.Закрыть();
	
КонецФункции

&НаСервере
Функция HTML_ПолеСтрокаКоманды(Знач Команда, Знач ИмяПоля)
	
	Зн = Неопределено;
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Если Команда.Свойство(ИмяПоля, Зн) Тогда
			Возврат Строка(Зн);
		КонецЕсли;
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Зн = Команда.Получить(ИмяПоля);
		Если Зн = Неопределено Тогда
			Возврат "";
		КонецЕсли;
		Возврат Строка(Зн);
	КонецЕсли;
	Возврат "";
	
КонецФункции

&НаСервере
Функция HTML_ИндексСтрокиИзКомандыМоста(Знач Команда)
	
	// Нельзя брать индекс через ПустаяСтрока(Строка(i)): для i = 0 строка может оказаться пустой.
	Зн = Неопределено;
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Если НЕ Команда.Свойство("i", Зн) Тогда
			Возврат -1;
		КонецЕсли;
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Зн = Команда.Получить("i");
		Если Зн = Неопределено Тогда
			Возврат -1;
		КонецЕсли;
	Иначе
		Возврат -1;
	КонецЕсли;
	Попытка
		Инд = Число(Строка(Зн));
	Исключение
		Возврат -1;
	КонецПопытки;
	Если Инд < 0 Тогда
		Возврат -1;
	КонецЕсли;
	Возврат Инд;
	
КонецФункции

&НаСервере
Функция HTML_НазваниеМесяцаРус(Знач НомерМесяца)
	
	Мас = СтрРазделить("Январь,Февраль,Март,Апрель,Май,Июнь,Июль,Август,Сентябрь,Октябрь,Ноябрь,Декабрь", ",");
	Н = Число(НомерМесяца);
	Если Н < 1 Или Н > 12 Тогда
		Возврат "";
	КонецЕсли;
	Возврат Мас[Н - 1];
	
КонецФункции

&НаСервере
Функция HTML_ПолеБулевоКоманды(Знач Команда, Знач ИмяПоля = "v")
	
	Зн = Неопределено;
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Если Команда.Свойство(ИмяПоля, Зн) Тогда
			Возврат Зн = Истина;
		КонецЕсли;
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Зн = Команда.Получить(ИмяПоля);
		Возврат Зн = Истина;
	КонецЕсли;
	Возврат Ложь;
	
КонецФункции

&НаСервере
Процедура HTML_ПодборБазПереключить(Знач Ид, Знач Вкл)
	
	М = HTML_МассивСтрокИзJson(HTML_JSONПодборБаз);
	НовМ = Новый Массив;
	УжеЕсть = Ложь;
	Для Каждого Эл Из М Цикл
		Если Эл = Ид Тогда
			УжеЕсть = Истина;
			Если Вкл Тогда
				НовМ.Добавить(Эл);
			КонецЕсли;
		Иначе
			НовМ.Добавить(Эл);
		КонецЕсли;
	КонецЦикла;
	Если Вкл И НЕ УжеЕсть Тогда
		НовМ.Добавить(Ид);
	КонецЕсли;
	HTML_JSONПодборБаз = HTML_JsonИзМассиваСтрок(НовМ);
	
КонецПроцедуры

&НаСервере
Процедура HTML_ПодборПользователейПереключить(Знач Ид, Знач Вкл)
	
	М = HTML_МассивСтрокИзJson(HTML_JSONПодборПользователей);
	НовМ = Новый Массив;
	УжеЕсть = Ложь;
	Для Каждого Эл Из М Цикл
		Если Эл = Ид Тогда
			УжеЕсть = Истина;
			Если Вкл Тогда
				НовМ.Добавить(Эл);
			КонецЕсли;
		Иначе
			НовМ.Добавить(Эл);
		КонецЕсли;
	КонецЦикла;
	Если Вкл И НЕ УжеЕсть Тогда
		НовМ.Добавить(Ид);
	КонецЕсли;
	HTML_JSONПодборПользователей = HTML_JsonИзМассиваСтрок(НовМ);
	
	М2 = HTML_МассивСтрокИзJson(HTML_JSONПодборПользователей);
	Если Вкл Тогда
		параметр_Пользователь = Ид;
	Иначе
		Если параметр_Пользователь = Ид Тогда
