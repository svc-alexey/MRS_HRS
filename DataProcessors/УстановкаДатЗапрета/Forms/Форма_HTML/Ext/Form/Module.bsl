Функция HTML_МассивСтрокИзJson(Знач JsonТекст)
	
	Рез = Новый Массив;
	Если ПустаяСтрока(JsonТекст) Тогда
		Возврат Рез;
	КонецЕсли;
	Попытка
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(JsonТекст);
		Дан = ПрочитатьJSON(Чтение);
		Если ТипЗнч(Дан) <> Тип("Массив") Тогда
			Возврат Рез;
		КонецЕсли;
		Для Каждого Эл Из Дан Цикл
			Рез.Добавить(Строка(Эл));
		КонецЦикла;
	Исключение
	КонецПопытки;
	Возврат Рез;
	
