&НаСервере
Функция СобратьПолныйHTMLДокументНаСервере()
	
	БазаПодключена = ЗначениеЗаполнено(ВыбраннаяБаза);
	Вкладка = АктивнаяВкладкаHTML;
	Если ПустаяСтрока(Вкладка) Тогда
		Вкладка = "t1";
	КонецЕсли;
	
	HTML = "<!DOCTYPE html><html><head><meta charset=""utf-8""/><style>" + СтильHTMLИнтерфейса() + "</style></head><body>";
	HTML = HTML + "<header class=""hdr""><h1 class=""title-main"">" + HTML_IconCalendarSVG() + "<span>Установка дат запрета</span></h1></header>";
	Если РежимДемоДанныхHTML() Тогда
		HTML = HTML + "<div class=""demo"">" + HTML_IconBellSVG() + "<span>Обработка использует Демо-данные!</span></div>";
	КонецЕсли;
	
	HTML = HTML + "<div class=""tabs"">";
	Ссылка = HrefКомандыМоста(Новый Структура("c,t", "tab", "t1"));
	КлассАкт = ?(Вкладка = "t1", "act", "");
	HTML = HTML + "<a class=""" + КлассАкт + """ href=""" + Ссылка + """>Основная</a>";
	Если БазаПодключена Тогда
		Ссылка = HrefКомандыМоста(Новый Структура("c,t", "tab", "t2"));
		КлассАкт = ?(Вкладка = "t2", "act", "");
		HTML = HTML + "<a class=""" + КлассАкт + """ href=""" + Ссылка + """>Даты в базе</a>";
	КонецЕсли;
	Если РасширеннаяФункциональность Тогда
		Ссылка = HrefКомандыМоста(Новый Структура("c,t", "tab", "t3"));
		КлассАкт = ?(Вкладка = "t3", "act", "");
		HTML = HTML + "<a class=""" + КлассАкт + """ href=""" + Ссылка + """>Параметры</a>";
	КонецЕсли;
	HTML = HTML + "</div>";
	
	Если Вкладка = "t1" Тогда
		HTML = HTML + СформироватьHTMLВкладкаОсновнаяНаСервере(БазаПодключена);
	ИначеЕсли Вкладка = "t2" И БазаПодключена Тогда
		HTML = HTML + СформироватьHTMLВкладкаИзБазыНаСервере();
	ИначеЕсли Вкладка = "t3" И РасширеннаяФункциональность Тогда
		HTML = HTML + СформироватьHTMLВкладкаПараметрыНаСервере();
	Иначе
		HTML = HTML + "<p class=""hint"">Раздел недоступен. Выберите базу или откройте вкладку ""Основная"".</p>";
	КонецЕсли;
	
	HTML = HTML + "</body></html>";
	Возврат HTML;
	
КонецФункции

&НаСервере
Функция СформироватьHTMLВкладкаОсновнаяНаСервере(Знач БазаПодключена)
	
	Ч = "";
	
	Ч = Ч + "<h2>База данных</h2>";
	Ч = Ч + "<p class=""hint"">Отметьте одну или несколько информационных баз, затем нажмите «Применить выбор». Чип с синей обводкой — текущая база (от неё загружаются организации и пользователи); клик по названию в чипе переключает активную базу.</p>";
	Ч = Ч + "<div class=""pick-panel"">";
	НомБ = 0;
	Для Каждого Стр Из БазыДанных Цикл
		Отм = HTML_ИдВПодбореБаз(Стр.Идентификатор);
		Метка = HTMLЭкранировать(Стр.Наименование) + " <span style=""opacity:.75"">(" + HTMLЭкранировать(Стр.СтатусБазы) + ")</span>";
		КлассЛинкБаза = ?(Отм, "pick-line on", "pick-line");
		СсылкаТогглБаза = HrefКомандыМоста(Новый Структура("c,i", "togglePickBase", HTML_ИндексДляJson(НомБ)));
		Ч = Ч + "<a class=""" + КлассЛинкБаза + """ href=""" + СсылкаТогглБаза + """ title=""Отметить / снять""><span class=""cb-box""></span><span class=""pick-txt"">" + Метка + "</span></a>";
		НомБ = НомБ + 1;
	КонецЦикла;
	Если БазыДанных.Количество() = 0 Тогда
		Ч = Ч + "<p class=""hint"">Нет доступных баз в списке.</p>";
	КонецЕсли;
	Ч = Ч + "<p style=""margin-top:12px""><a class=""btn"" href=""" + HrefКомандыМоста(Новый Структура("c", "applyBases")) + """>Применить выбор</a>";
	Ч = Ч + "<a class=""btn btn-ghost"" href=""" + HrefКомандыМоста(Новый Структура("c", "clearBasePick")) + """>Сбросить</a></p>";
	Ч = Ч + "</div>";
	
	Ч = Ч + "<div class=""chips"">";
	МИдБаз = HTML_МассивСтрокИзJson(HTML_JSONПодборБаз);
	НомЧБ = 0;
	Для Каждого ИдБ Из МИдБаз Цикл
		ИмяЧип = HTMLЭкранировать(HTML_НаименованиеБазыПоИд(ИдБ));
		КлассЧип = ?(ИдБ = параметр_БазаДанных, "chip chip-act", "chip");
		СсылкаАкт = HrefКомандыМоста(Новый Структура("c,i", "activateBase", HTML_ИндексДляJson(НомЧБ)));
		СсылкаУд = HrefКомандыМоста(Новый Структура("c,i", "removePickBase", HTML_ИндексДляJson(НомЧБ)));
		Ч = Ч + "<span class=""" + КлассЧип + """><a href=""" + СсылкаАкт + """>" + ИмяЧип + "</a>";
		Ч = Ч + "<a class=""x"" href=""" + СсылкаУд + """ title=""Убрать из выбора"">×</a></span>";
		НомЧБ = НомЧБ + 1;
	КонецЦикла;
	Ч = Ч + "</div>";
	
	Если НЕ БазаПодключена Тогда
		Ч = Ч + "<p class=""hint"">Чтобы загрузить пользователей и организации, примените выбор хотя бы одной базы.</p>";
		Возврат Ч;
	КонецЕсли;
	
	Ч = Ч + "<h2>Организации в базе (справка)</h2>";
	Ч = Ч + "<p class=""hint"">Список обновляется при смене активной базы (клик по чипу или «Применить выбор»). Выбор здесь не требуется.</p>";
	Ч = Ч + "<div class=""org-ref"">";
	Для Каждого Стр Из ОрганизацииИБ Цикл
		Ч = Ч + "<div class=""org-card""><div class=""nm"">" + HTMLЭкранировать(Стр.name) + "</div>";
		Ч = Ч + "<div class=""meta"">ИНН " + HTMLЭкранировать(Стр.inn) + ?(ПустаяСтрока(Стр.kpp), "", " · КПП " + HTMLЭкранировать(Стр.kpp)) + "</div></div>";
	КонецЦикла;
	Ч = Ч + "</div>";
	Если ОрганизацииИБ.Количество() = 0 Тогда
		Ч = Ч + "<p class=""hint"">Организации не загружены.</p>";
	КонецЕсли;
	
	Ч = Ч + "<h2>Пользователь</h2>";
	Ч = Ч + "<p class=""hint"">Отметьте пользователей и нажмите «Применить». Активный пользователь для строк очереди подсвечен в чипах.</p>";
	Ч = Ч + "<div class=""pick-panel"">";
	НомП = 0;
	Для Каждого Стр Из ПользователиИБ Цикл
		ОтмП = HTML_ИдВПодбореПользователей(Строка(Стр.Идентификатор));
		МеткаП = HTMLЭкранировать(Стр.name) + " <span style=""opacity:.75"">(" + HTMLЭкранировать(Стр.domainName) + ")</span>";
		КлассЛинкПольз = ?(ОтмП, "pick-line on", "pick-line");
		СсылкаТогглПольз = HrefКомандыМоста(Новый Структура("c,i", "togglePickUser", HTML_ИндексДляJson(НомП)));
		Ч = Ч + "<a class=""" + КлассЛинкПольз + """ href=""" + СсылкаТогглПольз + """ title=""Отметить / снять""><span class=""cb-box""></span><span class=""pick-txt"">" + МеткаП + "</span></a>";
		НомП = НомП + 1;
	КонецЦикла;
	Ч = Ч + "<p style=""margin-top:12px""><a class=""btn"" href=""" + HrefКомандыМоста(Новый Структура("c", "applyUsers")) + """>Применить выбор</a>";
	Ч = Ч + "<a class=""btn btn-ghost"" href=""" + HrefКомандыМоста(Новый Структура("c", "clearUserPick")) + """>Сбросить</a></p>";
	Ч = Ч + "</div>";
	
	Ч = Ч + "<div class=""chips"">";
	МИдП = HTML_МассивСтрокИзJson(HTML_JSONПодборПользователей);
	НомЧП = 0;
	Для Каждого ИдП Из МИдП Цикл
		ИмяПЧ = HTMLЭкранировать(HTML_ИмяПользователяПоИд(ИдП));
		КлассП = ?(ИдП = параметр_Пользователь, "chip chip-act", "chip");
		СсылкаАктП = HrefКомандыМоста(Новый Структура("c,i", "activateUser", HTML_ИндексДляJson(НомЧП)));
		СсылкаУдП = HrefКомандыМоста(Новый Структура("c,i", "removePickUser", HTML_ИндексДляJson(НомЧП)));
		Ч = Ч + "<span class=""" + КлассП + """><a href=""" + СсылкаАктП + """>" + ИмяПЧ + "</a>";
		Ч = Ч + "<a class=""x"" href=""" + СсылкаУдП + """ title=""Убрать"">×</a></span>";
		НомЧП = НомЧП + 1;
	КонецЦикла;
	Ч = Ч + "</div>";
	
	Ч = Ч + "<h2>Параметры периода и задачи</h2>";
	Ч = Ч + "<p class=""hint"">Укажите день в календаре или введите дату в полях под календарём (формат <strong>гггг-мм-дд</strong>).</p>";
	Ч = Ч + "<div class=""cal-2col""><div class=""cal-block""><p class=""cal-h"">Дата открытия</p>" + HTML_ФрагментМиниКалендаря(Истина) + "</div>";
	Ч = Ч + "<div class=""cal-block""><p class=""cal-h"">Дата отключения</p>" + HTML_ФрагментМиниКалендаря(Ложь) + "</div></div>";
	Ч = Ч + "<p class=""hint"">Текущие даты (только просмотр; задать — календарём выше).</p>";
	Ч = Ч + "<div class=""date-inp-grid""><span class=""lbl"">Открытие</span><input class=""inp-date"" type=""text"" readonly=""readonly"" tabindex=""-1"" value=""" + HTMLЭкранировать(ДатаВСтрокуHTML(параметр_ДатаОткрытия)) + """/>";
	Ч = Ч + "<span class=""lbl"">Отключение</span><input class=""inp-date"" type=""text"" readonly=""readonly"" tabindex=""-1"" value=""" + HTMLЭкранировать(ДатаВСтрокуHTML(параметр_ДатаОтключения)) + """/></div>";
	Ч = Ч + "<p class=""hint"">Номер задачи — в поле над областью HTML.</p>";
	
	Ч = Ч + "<h2>Организации (участвуют в добавлении строк)</h2>";
	Ч = Ч + "<p><a class=""btn"" href=""" + HrefКомандыМоста(Новый Структура("c", "checkAll")) + """>Выбрать все</a>";
	Ч = Ч + "<a class=""btn btn2"" href=""" + HrefКомандыМоста(Новый Структура("c", "uncheckAll")) + """>убрать все</a></p>";
	Ч = Ч + "<table class=""tbl-orgs""><thead><tr><th>Организация (вкл/выкл)</th></tr></thead><tbody>";
	НомО = 0;
	Для Каждого Стр Из ТаблицаОрганизаций Цикл
		Предст = ПредставлениеОргВТаблице(Стр);
		КлассЛинкОрг = ?(Стр.Выбор, "pick-line on", "pick-line");
		СсылкаФлипОрг = HrefКомандыМоста(Новый Структура("c,i", "flipOrg", HTML_ИндексДляJson(НомО)));
		Ч = Ч + "<tr><td><a class=""" + КлассЛинкОрг + """ href=""" + СсылкаФлипОрг + """ title=""Вкл/выкл""><span class=""cb-box""></span><span class=""pick-txt"">" + HTMLЭкранировать(Предст) + "</span></a></td></tr>";
		НомО = НомО + 1;
	КонецЦикла;
	Ч = Ч + "</tbody></table>";
	
	Ч = Ч + "<h2>Очередь отправки</h2>";
	Ч = Ч + "<p><a class=""btn"" href=""" + HrefКомандыМоста(Новый Структура("c", "addRow")) + """>Добавить к отправке</a>";
	Ч = Ч + "<a class=""btn btn-ok"" href=""" + HrefКомандыМоста(Новый Структура("c", "install")) + """>Установить даты запрета</a>";
	Ч = Ч + "<a class=""btn btn-bad"" href=""" + HrefКомандыМоста(Новый Структура("c", "clearQueue")) + """>Очистить таблицу</a></p>";
	Ч = Ч + "<table><thead><tr><th>Пользователь</th><th>Организация</th><th>Открытие</th><th>Отключение</th><th>Задача</th></tr></thead><tbody>";
	Для Каждого Стр Из ДатыЗапрета Цикл
		Ч = Ч + "<tr><td>" + HTMLЭкранировать(Стр.ПользовательПредставление) + "</td>";
		Ч = Ч + "<td>" + HTMLЭкранировать(Стр.ОрганизацияПредставление) + "</td>";
		Ч = Ч + "<td>" + HTMLЭкранировать(Формат(Стр.ДатаОткрытия, "ДФ=dd.MM.yyyy")) + "</td>";
		Ч = Ч + "<td>" + HTMLЭкранировать(Формат(Стр.ДатаОкончанияСрокаДействияРазрещения, "ДФ=dd.MM.yyyy")) + "</td>";
		Ч = Ч + "<td>" + HTMLЭкранировать(Стр.Комментарий) + "</td></tr>";
	КонецЦикла;
	Ч = Ч + "</tbody></table>";
	
	Возврат Ч;
	
КонецФункции

&НаСервере
