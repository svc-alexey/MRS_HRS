Функция HTML_ПолеСтрокаКоманды(Знач Команда, Знач ИмяПоля)
	
	Зн = Неопределено;
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Если Команда.Свойство(ИмяПоля, Зн) Тогда
			Возврат Строка(Зн);
		КонецЕсли;
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Зн = Команда.Получить(ИмяПоля);
		Если Зн = Неопределено Тогда
			Возврат "";
		КонецЕсли;
		Возврат Строка(Зн);
	КонецЕсли;
	Возврат "";
	
