КонецПроцедуры

&НаСервере
Процедура ДобавлениеЗаписиВТаблицуНаСервере()
	
	ТаблОрг = РеквизитФормыВЗначение("ТаблицаОрганизаций");
	ВыбранныеОрганизации = ТаблОрг.НайтиСтроки(Новый Структура("Выбор", Истина));
	Для Каждого Строка ИЗ ВыбранныеОрганизации Цикл
		
		МассивПользователейСОрганизацией = ДатыЗапрета.НайтиСтроки(Новый Структура("ПользовательИдентификатор, ОрганизацияИдентификатор", параметр_Пользователь, Строка.Идентификатор));
		Если МассивПользователейСОрганизацией.Количество() > 0 Тогда
			Для Каждого Стр Из МассивПользователейСОрганизацией Цикл
				ДатыЗапрета.Удалить(Стр);
			КонецЦикла;
		КонецЕсли;
		
		Стр = ДатыЗапрета.Добавить();
		Стр.ПользовательИдентификатор          		= параметр_Пользователь;
		Стр.Комментарий								= параметр_НомерЗадачи;
		Стр.ПользовательПредставление				= ПользователиИБ.НайтиСтроки(Новый Структура("Идентификатор", параметр_Пользователь))[0].name;
		Стр.ОрганизацияИдентификатор				= Строка.Идентификатор;
		Стр.ДатаОткрытия							= параметр_ДатаОткрытия;
		Стр.ДатаОкончанияСрокаДействияРазрещения	= параметр_ДатаОтключения;
		Стр.ОрганизацияПредставление				= ОрганизацииИБ.НайтиСтроки(Новый Структура("Идентификатор", Строка.Идентификатор))[0].name;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция СтруктураЗаписиОтправки(Строка)
	
	СтруктураПользователя = СтруктураПользователя(Строка.ПользовательИдентификатор);

	Если ЗначениеЗаполнено(Строка.ОрганизацияИдентификатор) Тогда
		Организация = ДанныеИзВнеш("ОрганизацииИБ", Строка.ОрганизацияИдентификатор);
		СтруктураОрганизации = Новый Структура; 
		СтруктураОрганизации.Вставить("guid",  Организация.guid);
		СтруктураОрганизации.Вставить("inn",   Организация.inn);
		СтруктураОрганизации.Вставить("kpp",   Организация.kpp);
		СтруктураОрганизации.Вставить("name",  Организация.name);
	КонецЕсли;
	ДанныеДляУстановки = Новый Структура;
	ДанныеДляУстановки.Вставить("users", 		СтруктураПользователя);
	ДанныеДляУстановки.Вставить("org", 			СтруктураОрганизации);
	ДанныеДляУстановки.Вставить("DateDelete", 	XMLСтрока(Строка.ДатаОкончанияСрокаДействияРазрещения));
	ДанныеДляУстановки.Вставить("dateInstall", 	XMLСтрока(Строка.ДатаОткрытия)); 
	ДанныеДляУстановки.Вставить("taskNumber", 	Строка.Комментарий);
		
	Возврат ДанныеДляУстановки;
	
КонецФункции

&НаСервере
Функция СтруктураПользователя(ИдентификаторПользователя)
	
	Пользователь = ДанныеИзВнеш("ПользователиИБ", ИдентификаторПользователя);
	СтруктураПользователя = Новый Структура;
	СтруктураПользователя.Вставить("guid", Пользователь.guid);
	СтруктураПользователя.Вставить("domainName", Пользователь.domainName);
	СтруктураПользователя.Вставить("name", Пользователь.name);
	Возврат СтруктураПользователя;

КонецФункции

&НаСервере
Функция ДанныеИзВнеш(Знач ИмяТаблицы, Знач Идентификатор)
	
	СтрокаТаблицы = ЭтотОбъект[ИмяТаблицы].НайтиСтроки(Новый Структура("Идентификатор", Идентификатор));
	Возврат СтрокаТаблицы[0];
	
КонецФункции

&НаСервере
Процедура УстановитьДатуЗапретаПользователямНаСервере()
	
	МассивЗаписей = Новый Массив;
	
	Для Каждого Строка из ДатыЗапрета Цикл
		СтруктураЗаписи = СтруктураЗаписиОтправки(Строка); 
		МассивЗаписей.Добавить(СтруктураЗаписи);
	КонецЦикла;
	
	ДанныеДляОтправки = МодульКоннекторХТТП().ОбъектВJson(МассивЗаписей);
	
	Ответ = ВыполнитьЗапросHTTP("accessPeriods", "Post", ДанныеДляОтправки);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеСпискаБаз()
	
	Если НЕ Метаданные.Справочники.Найти("БазыДанных") = Неопределено Тогда
		
		ТекстЗапроса = ТекстЗапросаПоСпискуБаз();
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса; 
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Стр = БазыДанных.Добавить();
			ЗаполнитьЗначенияСвойств(Стр,Выборка);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаПоСпискуБаз()
	
	Перем ТекстЗапроса;
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(т.Ссылка)) КАК Идентификатор,
	               |	ПРЕДСТАВЛЕНИЕ(т.АдресПубликацииВебСервисов) КАК АдресПубликации,
	               |	ПРЕДСТАВЛЕНИЕ(т.ВидКонфигурации) КАК Конфигурация,
	               |	ПРЕДСТАВЛЕНИЕ(т.Пользователь) КАК Пользователь,
	               |	т.Пользователь.Пароль КАК Пароль,
	               |	т.Наименование КАК Наименование,
	               |	ПРЕДСТАВЛЕНИЕ(т.СтатусБазы) КАК СтатусБазы,
	               |	ЕСТЬNULL(БазыДанныхДополнительныеРеквизиты.Значение, 90) КАК ОтступДнейПериодаМакс
	               |ИЗ
	               |	Справочник.БазыДанных КАК т
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.УстановленныеРасширенияКонфигурации.СрезПоследних(, Расширение = ЗНАЧЕНИЕ(Справочник.РасширенияКонфигураций.ИТ_Bорк)) КАК рст
	               |		ПО (рст.БазаДанных = т.Ссылка)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БазыДанных.ДополнительныеРеквизиты КАК БазыДанныхДополнительныеРеквизиты
	               |		ПО т.Ссылка = БазыДанныхДополнительныеРеквизиты.Ссылка
	               |			И (БазыДанныхДополнительныеРеквизиты.Свойство.Имя = ""ДнейУдаленияДатыЗапрета"")
	               |ГДЕ
	               |	ИСТИНА
	               |	И рст.Активно = ИСТИНА
	               |	И т.СтатусБазы = ЗНАЧЕНИЕ(Перечисление.СтатусыБаз.Рабочая)";
	//Если РольДоступна("ПолныеПрава") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И т.СтатусБазы = ЗНАЧЕНИЕ(Перечисление.СтатусыБаз.Рабочая)", "");
	//КонецЕсли;
	
	Возврат ТекстЗапроса;

КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицыДанных()
	
	ПользователиИБ.Очистить();
	ОрганизацииИБ.Очистить();
	МассивПользователей = ВыполнитьЗапросHTTP("users", "Get"); 		

	Для Каждого Строка ИЗ МассивПользователей Цикл
		Стр = ПользователиИБ.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Строка);
		Стр.Идентификатор = Новый УникальныйИдентификатор;
	КонецЦикла;
	
	МассивОрганизаций   = ВыполнитьЗапросHTTP("organizations", "Get");
	
	Для Каждого Строка ИЗ МассивОрганизаций Цикл 
		Стр = ОрганизацииИБ.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Строка);
		Стр.Идентификатор = Новый УникальныйИдентификатор;
		СтрокаОрганизации = ТаблицаОрганизаций.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаОрганизации, Стр);
	КонецЦикла;
	
	ДатыЗапретаИзВнешнейБазы();
	
КонецПроцедуры

&НаСервере
Функция ВыполнитьЗапросHTTP(Знач Ресурс, Знач Метод, Знач ОтправкаДанных = Неопределено)
	
	Перем Параметры;
	
	Метод = ВРег(Метод);
	
	Адрес = СтрШаблон("%1/hs/userManagement/%2", ВыбраннаяБаза, Ресурс);
	
	Параметры = МодульКоннекторХТТП().НовыеПараметры();
	Параметры.Аутентификация = МодульКоннекторХТТП().НоваяАутентификацияBasic();
	Параметры.Аутентификация.Пользователь = Логин;
	Параметры.Аутентификация.Пароль = Пароль;
	Параметры.Заголовки = Новый Соответствие;
	Параметры.Заголовки.Вставить("Content-Type", "text/json; charset=utf-8");
	
	Если Метод = "POST" Тогда		
		Результат = МодульКоннекторХТТП().Post(Адрес, ОтправкаДанных, Параметры);
	ИначеЕсли Метод = "GET" Тогда 
		Результат = МодульКоннекторХТТП().Get(Адрес, , Параметры);
		ЧтенДанных = Новый ЧтениеДанных(Результат.Тело);
		РезультатJSON = ЧтенДанных.ПрочитатьСимволы();
		Результат = МодульКоннекторХТТП().JsonВОбъект(РезультатJSON, ,Новый Структура("ПрочитатьВСоответствие", Ложь));
	ИначеЕсли Метод = "DELETE" Тогда
		Результат = МодульКоннекторХТТП().Delete(Адрес, ОтправкаДанных , Параметры);
	Иначе
		ВызватьИсключение "Неизвестный метод";
	КонецЕсли;
	
	Если Истина
	И ТипЗнч(Результат) = Тип("Структура")
	и Результат.Свойство("КодСостояния")
	и НЕ Результат.КодСостояния = 200
	Тогда
		ЧтенДанных = Новый ЧтениеДанных(Результат.Тело);
		ТелоОтвета = ЧтенДанных.ПрочитатьСимволы();
		Результат.Вставить("ТекстОшибки", ТелоОтвета);
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОчиститьДатыЗапретаПользователямНаСервере()
	
	ТаблЧасть = ДатыЗапрета.Выгрузить();
	МассивПользователейДляУдаления = ТаблЧасть.ВыгрузитьКолонку("ПользовательИдентификатор");
	
	ПользователиКОтправке = Новый Массив;
	Для Каждого Строка Из МассивПользователейДляУдаления Цикл
		Пользователь = СтруктураПользователя(Строка);
		ДанныеДляУстановки = Новый Структура;
		ДанныеДляУстановки.Вставить("users", 		Пользователь);
		ПользователиКОтправке.Добавить(ДанныеДляУстановки);
	КонецЦикла;
		
	ДанныеДляОтправки = МодульКоннекторХТТП().ОбъектВJson(ПользователиКОтправке);
	Ответ = ВыполнитьЗапросHTTP("accessPeriods", "Delete", ДанныеДляОтправки);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборВТаблицеОрганизаций(Знач ПараметрКнопки)

	Для Каждого Строка Из ТаблицаОрганизаций Цикл
		Строка.Выбор = ПараметрКнопки; 	
	КонецЦикла;

КонецПроцедуры

#Область HTMLИнтерфейс

&НаСервереБезКонтекста
Функция РасшифроватьКомандуHTMLИзФрагмента(Знач ФрагментBase64URL)
	
	Если ПустаяСтрока(ФрагментBase64URL) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Стр = ФрагментBase64URL;
	Стр = СтрЗаменить(Стр, "-", "+");
	Стр = СтрЗаменить(Стр, "_", "/");
	Пока СтрДлина(Стр) % 4 <> 0 Цикл
		Стр = Стр + "=";
	КонецЦикла;
	
	Попытка
		ДД = Base64Значение(Стр);
		JsonТекст = ПолучитьСтрокуИзДвоичныхДанных(ДД, КодировкаТекста.UTF8);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(JsonТекст);
	Возврат ПрочитатьJSON(Чтение);
	
КонецФункции

&НаКлиенте
Функция ИмяКомандыИнтерфейса(Команда)
	
	Если Команда = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Возврат Строка(Команда.c);
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Возврат Строка(Команда.Получить("c"));
	КонецЕсли;
	Возврат "";
	
КонецФункции

&НаКлиенте
Процедура ПолеHTMLДокументаПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Href = "";
	Если ДанныеСобытия <> Неопределено Тогда
		Попытка
			Href = ДанныеСобытия.Href;
		Исключение
			Href = "";
		КонецПопытки;
	КонецЕсли;
	
	Если ПустаяСтрока(Href) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ СтрНачинаетсяС(НРег(Href), "mrsdz://") Тогда
		Возврат;
	КонецЕсли;
	
	Поз = СтрНайти(Href, "#");
	Если Поз = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Фрагмент = Сред(Href, Поз + 1);
	Если ПустаяСтрока(Фрагмент) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Команда = РасшифроватьКомандуHTMLИзФрагмента(Фрагмент);
	Имя = ИмяКомандыИнтерфейса(Команда);
	
	Если Имя = "addRow" Тогда
		ОбработатьОшибки();
		Возврат;
	ИначеЕсли Имя = "install" Тогда
		УстановитьДатуЗапретаПользователям(Неопределено);
		Возврат;
	ИначеЕсли Имя = "clearRemote" Тогда
		ОчиститьДатыЗапретаПользователям(Неопределено);
		Возврат;
	ИначеЕсли Имя = "refreshDb" Тогда
		ОбновитьИнформацию(Неопределено);
		Возврат;
	ИначеЕсли Имя = "checkAll" Тогда
		ВыборВТаблицеОрганизаций(Истина);
		ОбновитьОтображениеHTML();
		Возврат;
	ИначеЕсли Имя = "uncheckAll" Тогда
		ВыборВТаблицеОрганизаций(Ложь);
		ОбновитьОтображениеHTML();
		Возврат;
	КонецЕсли;
	
	ВыполнитьКомандуИнтерфейсаНаСервере(Команда);
	ОбновитьОтображениеHTML();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтображениеHTML()
	ТекстПоляHTML = СформироватьТекстHTMLНаСервере();
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуИнтерфейсаНаСервере(Знач Команда)
	
	Если Команда = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Имя = "";
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Имя = Строка(Команда.c);
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Имя = Строка(Команда.Получить("c"));
	Иначе
		Возврат;
	КонецЕсли;
	
	Если Имя = "selectBase" Тогда
		ИдБазы = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИдБазы = Строка(Команда.id);
		Иначе
			ИдБазы = Строка(Команда.Получить("id"));
		КонецЕсли;
		ВыполнитьВыборБазыНаСервере(ИдБазы);
	ИначеЕсли Имя = "setField" Тогда
		ИмяПоля = ""; ЗначПоля = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИмяПоля = Строка(Команда.n);
			ЗначПоля = Строка(Команда.v);
		Иначе
			ИмяПоля = Строка(Команда.Получить("n"));
			ЗначПоля = Строка(Команда.Получить("v"));
		КонецЕсли;
		УстановитьПолеФормыИзHTMLНаСервере(ИмяПоля, ЗначПоля);
	ИначеЕсли Имя = "toggleOrg" Тогда
		ИдОрг = ""; Вкл = Ложь;
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИдОрг = Строка(Команда.id);
			Вкл = Команда.v = Истина;
		Иначе
			ИдОрг = Строка(Команда.Получить("id"));
			Вкл = Команда.Получить("v") = Истина;
		КонецЕсли;
		УстановитьФлажокОрганизацииИзHTMLНаСервере(ИдОрг, Вкл);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьВыборБазыНаСервере(Знач ИдентификаторБазы)
	
	параметр_Пользователь = "";
	параметр_Организация = "";
	ТаблицаОрганизаций.Очистить();
	ДатыЗапрета.Очистить();
	ОрганизацииИБ.Очистить();
	ПользователиИБ.Очистить();
	
	Если ПустаяСтрока(ИдентификаторБазы) Тогда
		параметр_БазаДанных = "";
		ВыбраннаяБаза = "";
		Логин = "";
		Пароль = "";
		Возврат;
	КонецЕсли;
	
	Найденные = БазыДанных.НайтиСтроки(Новый Структура("Идентификатор", ИдентификаторБазы));
	Если Найденные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаБазы = Найденные[0];
	Логин = СтрокаБазы.Пользователь;
	Пароль = СтрокаБазы.Пароль;
	ВыбраннаяБаза = СтрокаБазы.АдресПубликации;
	параметр_БазаДанных = ИдентификаторБазы;
	
	ЗаполнитьТаблицыДанных();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПолеФормыИзHTMLНаСервере(Знач ИмяПоля, Знач Значение)
	
	Если ИмяПоля = "user" Тогда
		параметр_Пользователь = Значение;
	ИначеЕсли ИмяПоля = "org" Тогда
		параметр_Организация = Значение;
	ИначеЕсли ИмяПоля = "task" Тогда
		параметр_НомерЗадачи = Значение;
	ИначеЕсли ИмяПоля = "dOpen" Тогда
		параметр_ДатаОткрытия = ДатаИзСтрокиИнтерфейса(Значение);
	ИначеЕсли ИмяПоля = "dClose" Тогда
		параметр_ДатаОтключения = ДатаИзСтрокиИнтерфейса(Значение);
	ИначеЕсли ИмяПоля = "login" Тогда
		Логин = Значение;
	ИначеЕсли ИмяПоля = "password" И ЗначениеЗаполнено(Значение) Тогда
		Пароль = Значение;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДатаИзСтрокиИнтерфейса(Знач Стр)
	
	Стр = СокрЛП(Стр);
	Если ПустаяСтрока(Стр) Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;
	Части = СтрРазделить(Стр, "-");
	Если Части.Количество() <> 3 Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;
	Попытка
		Возврат Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));
	Исключение
		Возврат Дата(1, 1, 1);
	КонецПопытки;
	
КонецФункции

&НаСервере
Процедура УстановитьФлажокОрганизацииИзHTMLНаСервере(Знач ИдОрг, Знач Вкл)
	
	Найденные = ТаблицаОрганизаций.НайтиСтроки(Новый Структура("Идентификатор", ИдОрг));
	Если Найденные.Количество() > 0 Тогда
		Найденные[0].Выбор = Вкл;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СформироватьТекстHTMLНаСервере()
	
	Состояние = СобратьСостояниеИнтерфейса();
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Состояние);
	JsonТекст = Запись.Закрыть();
	
	ДД = ПолучитьДвоичныеДанныеИзСтроки(JsonТекст, КодировкаТекста.UTF8);
	B64 = Base64Строка(ДД);
	
	Шаблон = ТекстШаблонаHTML();
	Возврат СтрЗаменить(Шаблон, "@@@B64@@@", B64);
	
КонецФункции

&НаСервере
Функция СобратьСостояниеИнтерфейса()
	
	БазаПодключена = ЗначениеЗаполнено(ВыбраннаяБаза);
	
	МассивБаз = Новый Массив;
	Для Каждого Стр Из БазыДанных Цикл
		Эл = Новый Структура;
		Эл.Вставить("id", Стр.Идентификатор);
		Эл.Вставить("title", Стр.Наименование);
		Эл.Вставить("status", Стр.СтатусБазы);
		МассивБаз.Добавить(Эл);
	КонецЦикла;
	
	МассивПользователей = Новый Массив;
	Для Каждого Стр Из ПользователиИБ Цикл
		Эл = Новый Структура("id,name", Стр.Идентификатор, Стр.name);
		МассивПользователей.Добавить(Эл);
	КонецЦикла;
	
	МассивОргСписка = Новый Массив;
	Для Каждого Стр Из ОрганизацииИБ Цикл
		Эл = Новый Структура("id,name", Стр.Идентификатор, Стр.name);
		МассивОргСписка.Добавить(Эл);
	КонецЦикла;
	
	МассивТабОрг = Новый Массив;
	Для Каждого Стр Из ТаблицаОрганизаций Цикл
		Эл = Новый Структура("id,name,sel", Стр.Идентификатор, Стр.Name, Стр.Выбор);
		МассивТабОрг.Добавить(Эл);
	КонецЦикла;
	
	МассивОчереди = Новый Массив;
	Для Каждого Стр Из ДатыЗапрета Цикл
		Эл = Новый Структура;
		Эл.Вставить("pu", Стр.ПользовательПредставление);
		Эл.Вставить("op", Стр.ОрганизацияПредставление);
		Эл.Вставить("d1", Формат(Стр.ДатаОткрытия, "ДФ=dd.MM.yyyy"));
		Эл.Вставить("d2", Формат(Стр.ДатаОкончанияСрокаДействияРазрещения, "ДФ=dd.MM.yyyy"));
		Эл.Вставить("cm", Стр.Комментарий);
		МассивОчереди.Добавить(Эл);
	КонецЦикла;
	
	МассивИзБазы = Новый Массив;
	Для Каждого Стр Из ДатыЗапретаИзБазы Цикл
		Эл = Новый Структура("u,o,d,c", Стр.user, Стр.org, Стр.date, Стр.comment);
		МассивИзБазы.Добавить(Эл);
	КонецЦикла;
	
	МассивБазРасш = Новый Массив;
	Для Каждого Стр Из БазыДанных Цикл
		Эл = Новый Структура;
		Эл.Вставить("id", Стр.Идентификатор);
		Эл.Вставить("title", Стр.Наименование);
		Эл.Вставить("cfg", Стр.Конфигурация);
		Эл.Вставить("url", Стр.АдресПубликации);
		Эл.Вставить("status", Стр.СтатусБазы);
		Эл.Вставить("user", Стр.Пользователь);
		МассивБазРасш.Добавить(Эл);
	КонецЦикла;
	
	ПоляФормы = Новый Структура;
	ПоляФормы.Вставить("user", параметр_Пользователь);
	ПоляФормы.Вставить("org", параметр_Организация);
	ПоляФормы.Вставить("dOpen", ДатаВСтрокуHTML(параметр_ДатаОткрытия));
	ПоляФормы.Вставить("dClose", ДатаВСтрокуHTML(параметр_ДатаОтключения));
	ПоляФормы.Вставить("task", параметр_НомерЗадачи);
	ПоляФормы.Вставить("login", Логин);
	
	Состояние = Новый Структура;
	Состояние.Вставить("bases", МассивБаз);
	Состояние.Вставить("selectedBaseId", параметр_БазаДанных);
	Состояние.Вставить("baseConnected", БазаПодключена);
	Состояние.Вставить("paramsEnabled", БазаПодключена);
	Состояние.Вставить("extended", РасширеннаяФункциональность);
	Состояние.Вставить("users", МассивПользователей);
	Состояние.Вставить("orgs", МассивОргСписка);
	Состояние.Вставить("torg", МассивТабОрг);
	Состояние.Вставить("queue", МассивОчереди);
	Состояние.Вставить("fromDb", МассивИзБазы);
	Состояние.Вставить("f", ПоляФормы);
	Состояние.Вставить("basesExt", МассивБазРасш);
	
	Возврат Состояние;
	
КонецФункции

&НаСервере
Функция ДатаВСтрокуHTML(Знач Д)
	
	Если НЕ ЗначениеЗаполнено(Д) Или Д = Дата(1, 1, 1) Тогда
		Возврат "";
	КонецЕсли;
	Возврат Формат(Д, "ДФ=yyyy-MM-dd");
	
КонецФункции

