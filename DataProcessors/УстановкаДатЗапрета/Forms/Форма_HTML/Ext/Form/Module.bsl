	ТекстПоляHTML = СформироватьТекстHTMLНаСервере();
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуИнтерфейсаНаСервере(Знач Команда)
	
	Если Команда = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Имя = "";
	Если ТипЗнч(Команда) = Тип("Структура") Тогда
		Имя = Строка(Команда.c);
	ИначеЕсли ТипЗнч(Команда) = Тип("Соответствие") Тогда
		Имя = Строка(Команда.Получить("c"));
	Иначе
		Возврат;
	КонецЕсли;
	
	Если Имя = "selectBase" Тогда
		ИдБазы = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИдБазы = Строка(Команда.id);
		Иначе
			ИдБазы = Строка(Команда.Получить("id"));
		КонецЕсли;
		ВыполнитьВыборБазыНаСервере(ИдБазы, Истина);
	ИначеЕсли Имя = "togglePickBase" Тогда
		Ид = HTML_ПолеСтрокаКоманды(Команда, "id");
		Вкл = НЕ HTML_ИдВПодбореБаз(Ид);
		HTML_ПодборБазПереключить(Ид, Вкл);
	ИначеЕсли Имя = "removePickBase" Тогда
		Ид = HTML_ПолеСтрокаКоманды(Команда, "id");
		HTML_ПодборБазПереключить(Ид, Ложь);
	ИначеЕсли Имя = "applyBases" Тогда
		HTML_ПрименитьПодборБаз();
	ИначеЕсли Имя = "clearBasePick" Тогда
		HTML_JSONПодборБаз = HTML_ПустойМассивСтрокJson();
		ВыполнитьВыборБазыНаСервере("", Истина);
	ИначеЕсли Имя = "activateBase" Тогда
		Ид = HTML_ПолеСтрокаКоманды(Команда, "id");
		Если НЕ ПустаяСтрока(Ид) Тогда
			ВыполнитьВыборБазыНаСервере(Ид, Ложь);
		КонецЕсли;
	ИначеЕсли Имя = "togglePickUser" Тогда
		Ид = HTML_ПолеСтрокаКоманды(Команда, "id");
		Вкл = НЕ HTML_ИдВПодбореПользователей(Ид);
		HTML_ПодборПользователейПереключить(Ид, Вкл);
	ИначеЕсли Имя = "removePickUser" Тогда
		Ид = HTML_ПолеСтрокаКоманды(Команда, "id");
		HTML_ПодборПользователейПереключить(Ид, Ложь);
	ИначеЕсли Имя = "applyUsers" Тогда
		HTML_ПрименитьПодборПользователей();
	ИначеЕсли Имя = "clearUserPick" Тогда
		HTML_JSONПодборПользователей = HTML_ПустойМассивСтрокJson();
		параметр_Пользователь = "";
	ИначеЕсли Имя = "activateUser" Тогда
		параметр_Пользователь = HTML_ПолеСтрокаКоманды(Команда, "id");
	ИначеЕсли Имя = "setField" Тогда
		ИмяПоля = ""; ЗначПоля = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИмяПоля = Строка(Команда.n);
			ЗначПоля = Строка(Команда.v);
		Иначе
			ИмяПоля = Строка(Команда.Получить("n"));
			ЗначПоля = Строка(Команда.Получить("v"));
		КонецЕсли;
		УстановитьПолеФормыИзHTMLНаСервере(ИмяПоля, ЗначПоля);
	ИначеЕсли Имя = "toggleOrg" Тогда
		ИдОрг = HTML_ПолеСтрокаКоманды(Команда, "id");
		Вкл = HTML_ПолеБулевоКоманды(Команда, "v");
		УстановитьФлажокОрганизацииИзHTMLНаСервере(ИдОрг, Вкл);
	ИначеЕсли Имя = "tab" Тогда
		КодВкладки = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			КодВкладки = Строка(Команда.t);
		Иначе
			КодВкладки = Строка(Команда.Получить("t"));
		КонецЕсли;
		Если КодВкладки = "t1" Или КодВкладки = "t2" Или КодВкладки = "t3" Тогда
			АктивнаяВкладкаHTML = КодВкладки;
		КонецЕсли;
	ИначеЕсли Имя = "setOrgSel" Тогда
		ИдОрг = ""; Вкл = Ложь;
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИдОрг = Строка(Команда.id);
			Вкл = Команда.v = Истина;
		Иначе
			ИдОрг = Строка(Команда.Получить("id"));
			Вкл = Команда.Получить("v") = Истина;
		КонецЕсли;
		УстановитьФлажокОрганизацииИзHTMLНаСервере(ИдОрг, Вкл);
	ИначеЕсли Имя = "flipOrg" Тогда
		ИдОрг = "";
		Если ТипЗнч(Команда) = Тип("Структура") Тогда
			ИдОрг = Строка(Команда.id);
		Иначе
			ИдОрг = Строка(Команда.Получить("id"));
		КонецЕсли;
		Найденные = ТаблицаОрганизаций.НайтиСтроки(Новый Структура("Идентификатор", ИдОрг));
		Если Найденные.Количество() > 0 Тогда
			Найденные[0].Выбор = НЕ Найденные[0].Выбор;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьВыборБазыНаСервере(Знач ИдентификаторБазы, Знач СброситьПодборБаз = Истина)
	
	Если СброситьПодборБаз Тогда
		Если ПустаяСтрока(ИдентификаторБазы) Тогда
			HTML_JSONПодборБаз = HTML_ПустойМассивСтрокJson();
		Иначе
			МПодбор = Новый Массив;
			МПодбор.Добавить(ИдентификаторБазы);
			HTML_JSONПодборБаз = HTML_JsonИзМассиваСтрок(МПодбор);
		КонецЕсли;
	КонецЕсли;
	
	параметр_Пользователь = "";
	параметр_Организация = "";
	HTML_JSONПодборПользователей = HTML_ПустойМассивСтрокJson();
	ТаблицаОрганизаций.Очистить();
	ДатыЗапрета.Очистить();
	ОрганизацииИБ.Очистить();
	ПользователиИБ.Очистить();
	
	Если ПустаяСтрока(ИдентификаторБазы) Тогда
		параметр_БазаДанных = "";
		ВыбраннаяБаза = "";
		Логин = "";
		Пароль = "";
		Возврат;
	КонецЕсли;
	
	Найденные = БазыДанных.НайтиСтроки(Новый Структура("Идентификатор", ИдентификаторБазы));
	Если Найденные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаБазы = Найденные[0];
	Логин = СтрокаБазы.Пользователь;
	Пароль = СтрокаБазы.Пароль;
	ВыбраннаяБаза = СтрокаБазы.АдресПубликации;
	параметр_БазаДанных = ИдентификаторБазы;
	
	ЗаполнитьТаблицыДанных();
	
КонецПроцедуры

&НаСервере
