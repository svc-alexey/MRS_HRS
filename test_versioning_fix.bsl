// Тестовый скрипт для проверки исправленной функции ГраницыУдаленияОбъектов()
// Этот файл можно выполнить в консоли 1С для проверки результата

Процедура ТестированиеГраницУдаления() Экспорт
	
	// Получаем таблицу границ удаления
	ГраницыУдаления = ВерсионированиеОбъектов.ГраницыУдаленияОбъектов();
	
	// Выводим результаты в консоль
	Сообщить("=== Результаты функции ГраницыУдаленияОбъектов() ===");
	Сообщить("");
	
	Для Каждого СтрокаГраницы Из ГраницыУдаления Цикл
		
		Сообщить("Граница удаления: " + Формат(СтрокаГраницы.ГраницаУдаления, "ДФ='dd.MM.yyyy HH:mm:ss'"));
		
		// Определяем срок хранения по дате границы
		Если СтрокаГраницы.ГраницаУдаления = Дата("00010101") Тогда
			Сообщить("Срок хранения: БЕССРОЧНО");
		Иначе
			РазницаВДнях = (ТекущаяДатаСеанса() - СтрокаГраницы.ГраницаУдаления) / 86400;
			Сообщить("Срок хранения: ~" + Формат(Окр(РазницаВДнях), "ЧЦ=4; ЧН=0; ЧГ=") + " дней");
		КонецЕсли;
		
		Сообщить("Типы объектов (" + Формат(СтрокаГраницы.СписокТипов.Количество(), "ЧН=0; ЧГ=") + " шт.):");
		
		// Выводим первые 10 типов для примера
		СчетчикТипов = 0;
		Для Каждого Тип Из СтрокаГраницы.СписокТипов Цикл
			СчетчикТипов = СчетчикТипов + 1;
			Если СчетчикТипов <= 10 Тогда
				МетаданныеТипа = Метаданные.НайтиПоТипу(Тип);
				Если МетаданныеТипа <> Неопределено Тогда
					Сообщить("  - " + МетаданныеТипа.ПолноеИмя());
				КонецЕсли;
			Иначе
				Сообщить("  ... и еще " + Формат(СтрокаГраницы.СписокТипов.Количество() - 10, "ЧН=0; ЧГ=") + " типов");
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Сообщить("");
		
	КонецЦикла;
	
	Сообщить("=== Конец тестирования ===");
	
КонецПроцедуры

// Проверка настроек версионирования из регистра
Процедура ПроверкаНастроекВерсионирования() Экспорт
	
	Сообщить("=== Настройки версионирования из регистра ===");
	Сообщить("");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИдентификаторыОбъектовМетаданных.ПолноеИмя КАК ПолноеИмя,
		|	НастройкиВерсионированияОбъектов.СрокХраненияВерсий КАК СрокХраненияВерсий,
		|	НастройкиВерсионированияОбъектов.СрокХраненияВерсий.Наименование КАК СрокХраненияВерсийНаименование
		|ИЗ
		|	РегистрСведений.НастройкиВерсионированияОбъектов КАК НастройкиВерсионированияОбъектов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ИдентификаторыОбъектовМетаданных КАК ИдентификаторыОбъектовМетаданных
		|		ПО НастройкиВерсионированияОбъектов.ТипОбъекта = ИдентификаторыОбъектовМетаданных.Ссылка
		|ГДЕ
		|	НЕ ИдентификаторыОбъектовМетаданных.ПометкаУдаления
		|	И ИдентификаторыОбъектовМетаданных.ЗначениеПустойСсылки <> НЕОПРЕДЕЛЕНО
		|
		|УПОРЯДОЧИТЬ ПО
		|	СрокХраненияВерсийНаименование,
		|	ПолноеИмя";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	ТекущийСрок = Неопределено;
	Счетчик = 0;
	
	Пока Выборка.Следующий() Цикл
		
		Если ТекущийСрок <> Выборка.СрокХраненияВерсий Тогда
			Если Счетчик > 0 Тогда
				Сообщить("");
			КонецЕсли;
			ТекущийСрок = Выборка.СрокХраненияВерсий;
			Сообщить("Срок хранения: " + Выборка.СрокХраненияВерсийНаименование);
			Счетчик = 0;
		КонецЕсли;
		
		Счетчик = Счетчик + 1;
		Сообщить("  " + Формат(Счетчик, "ЧН=0; ЧВН=; ЧГ=") + ". " + Выборка.ПолноеИмя);
		
	КонецЦикла;
	
	Сообщить("");
	Сообщить("=== Конец проверки настроек ===");
	
КонецПроцедуры

// Для быстрого запуска обеих проверок
Процедура ВыполнитьВсеПроверки() Экспорт
	
	ПроверкаНастроекВерсионирования();
	Сообщить("");
	Сообщить("=====================================");
	Сообщить("");
	ТестированиеГраницУдаления();
	
КонецПроцедуры
